{
  "name": "discord-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.19",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "register": "bun run src/deploy-commands.ts",
    "build": "tsc --project tsconfig.json",
    "check": "tsc --noEmit",
    "start": "bun run src/index.ts"
  },
  "dependencies": {
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "bun-types": "^1.3.10",
    "typescript": "^5.9.3"
  }
}
